<!DOCTYPE html>

<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - MyoStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        header {
            background: #0d6efd;
            color: white;
            padding: 15px 20px;
        }
        
        header h1 {
            margin: 0;
            font-size: 1.5rem;
        }
        
        .banner {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }
        
        nav {
            background: #f8f9fa;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #dee2e6;
        }
        
        nav ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            gap: 20px;
        }
        
        nav ul li a {
            text-decoration: none;
            color: #333;
            font-weight: 500;
        }
        
        nav ul li a:hover {
            color: #0d6efd;
        }
        
        nav form {
            display: flex;
            gap: 5px;
        }
        
        nav form input {
            padding: 5px 10px;
            border: 1px solid #ced4da;
            border-radius: 4px;
        }
        
        nav .cart-link {
            position: relative;
        }
        
        nav .cart-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background: red;
            color: white;
            border-radius: 50%;
            padding: 2px 6px;
            font-size: 0.7rem;
        }
        
        footer {
            background: #343a40;
            color: white;
            padding: 20px;
            text-align: center;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <header>
        <h1>MyoStore - E-Ticaret Sitesi</h1>
    </header>
    
    <img src="~/css/images/Gri Minimalist Mağaza Bannerı.png" class="banner" alt="Banner">
    
    <nav>
        <ul>
            <li><a href="/">Ana Sayfa</a></li>
            <li><a href="/Product">Ürünler</a></li>
            <li><a href="/Home/Privacy">Hakkımızda</a></li>
        </ul>
        
        <form action="/Product/Search" method="get">
            <input type="text" name="query" placeholder="Ürün ara...">
            <button type="submit" class="btn btn-sm btn-primary">Ara</button>
        </form>
        
        <div>
            <a href="/Cart" class="btn btn-outline-primary cart-link">
                Sepet
                <span class="cart-badge">0</span>
            </a>
        </div>
    </nav>

    @RenderBody()

    <footer>
        <p>&copy; 2024 MyoStore - Tüm hakları saklıdır.</p>
    </footer>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
