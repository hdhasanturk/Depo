@model List<MyoStore.Models.Product>

<div class="container mt-4">
    <h1 class="mb-4">Ürünlerimiz</h1>
    
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <a href="/Product" class="btn btn-outline-primary @(ViewBag.SelectedCategory == null ? "active" : "")">Tüm Ürünler</a>
                @foreach (var category in ViewBag.Categories)
                {
                    <a href="/Product?categoryId=@category.Id" 
                       class="btn btn-outline-primary @(ViewBag.SelectedCategory?.ToString() == category.Id.ToString() ? "active" : "")">
                        @category.Name
                    </a>
                }
            </div>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">Henüz ürün bulunmamaktadır.</div>
    }
    else
    {
        <div class="row">
            @foreach (var product in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Description</p>
                            <p class="text-success fw-bold">@product.Price.ToString("N0") TL</p>
                            <p class="small text-secondary">Stok: @product.Stock</p>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a href="/Product/Details/@product.Id" class="btn btn-sm btn-primary w-100">Detay</a>
                            <form action="/Cart/Add" method="post" class="mt-2">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-success w-100">Sepete Ekle</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
