@model MyoStore.Models.Cart

<div class="container mt-4">
    <h1 class="mb-4">Alışveriş Sepeti</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    @if (Model.Items.Count == 0)
    {
        <div class="alert alert-info">
            <p>Sepetiniz boş!</p>
            <a href="/Product" class="btn btn-primary">Alışverişe Başla</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                @foreach (var item in Model.Items)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-5">
                                    <h5>@item.Product?.Name</h5>
                                    <p class="text-muted small mb-0">@item.Product?.Description</p>
                                    <p class="text-success fw-bold mb-0">@item.Product?.Price.ToString("N0") TL</p>
                                </div>
                                <div class="col-md-3">
                                    <form action="/Cart/Update" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control">
                                            <button type="submit" class="btn btn-outline-secondary">Güncelle</button>
                                        </div>
                                    </form>
                                </div>
                                <div class="col-md-2 text-end">
                                    <p class="fw-bold mb-0">@((item.Product?.Price ?? 0) * item.Quantity).ToString("N0") TL</p>
                                </div>
                                <div class="col-md-1 text-end">
                                    <a href="/Cart/Remove/@item.ProductId" class="btn btn-sm btn-outline-danger">X</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mt-3">
                    <a href="/Cart/Clear" class="btn btn-outline-danger" onclick="return confirm('Sepeti temizlemek istediğinize emin misiniz?')">Sepeti Temizle</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Sipariş Özeti</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Toplam Ürün:</span>
                            <span>@Model.TotalItemCount</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Toplam:</strong>
                            <strong class="text-success">@Model.TotalPrice.ToString("N0") TL</strong>
                        </div>
                        <button class="btn btn-success w-100">Ödemeye Geç</button>
                        <a href="/Product" class="btn btn-outline-primary w-100 mt-2">Alışverişe Devam Et</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
